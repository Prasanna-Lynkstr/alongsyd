# Alongsyd environment — copy to .env.local and fill in from your Supabase project
# (Supabase dashboard → Project Settings → API)

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Active market. Selects the country config in src/config/country.ts.
# Optional — defaults to IN (India).
NEXT_PUBLIC_COUNTRY=IN

# Phone OTP sign-in. Off by default (email magic-link only). Set to "true" only
# after configuring an SMS provider in Supabase → Authentication → Providers.
NEXT_PUBLIC_PHONE_AUTH=false

# Server-only — NEVER expose to the browser or commit. Used by the seed script
# and by admin/moderation actions. (Supabase → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Server-only — powers semantic search (embeddings). Without it, search falls
# back to keyword full-text search. (platform.openai.com → API keys)
OPENAI_API_KEY=sk-...

# Web Push (VAPID). Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is exposed to the browser; private key is server-only. Without
# these, the notification opt-in is hidden and no pushes are sent.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# Scheduled jobs (Supabase pg_cron). A long random string; the pg_cron jobs in
# supabase/wave3-cron.sql send it as a Bearer token to the /api/cron/* routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
